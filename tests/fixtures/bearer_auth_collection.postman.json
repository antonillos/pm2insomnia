{
  "info": {
    "name": "Bearer Auth Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}"
      }
    ]
  },
  "item": [
    {
      "name": "Create resource",
      "request": {
        "method": "POST",
        "url": "https://api.example.com/resources"
      }
    }
  ]
}
